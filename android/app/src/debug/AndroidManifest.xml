<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- ACCESS_NETWORK_STATE diperlukan Firebase & library jaringan
         untuk mendeteksi ketersediaan koneksi internet. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Debug-only: izinkan HTTP (cleartext) traffic untuk development
         dengan server lokal / Firebase Emulator Suite. -->
    <application
        android:usesCleartextTraffic="true"
        tools:ignore="HardcodedDebugMode"
        tools:targetApi="28" />
</manifest>
