rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Fungsi bantu ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ───────────────────────────────────────────────
    // Setiap user bisa baca & edit data dirinya sendiri
    // Admin bisa akses semua user
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────
    // Customer hanya bisa lihat order miliknya (customerId == uid)
    // Admin bisa baca, buat, update, hapus semua order
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && (request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Missions ────────────────────────────────────────────
    // Semua user terautentikasi bisa lihat misi
    // Hanya admin yang bisa buat/ubah/hapus
    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Mission Progress ────────────────────────────────────
    // Customer hanya bisa baca & tulis progress miliknya
    // Admin bisa akses semua
    match /mission_progress/{progressId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && (request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid || isAdmin());
    }

    // ── Vouchers ────────────────────────────────────────────
    // Semua user terautentikasi bisa lihat voucher
    // Hanya admin yang bisa buat/ubah/hapus
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
